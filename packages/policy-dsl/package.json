{
  "name": "@sentinel/policy-dsl",
  "version": "0.1.0",
  "description": "Programmable policy DSL for Solana agent transaction firewalls — parse, evaluate, and canonicalize policies with zero I/O",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema.js",
    "./engine": "./dist/engine.js",
    "./canonicalize": "./dist/canonicalize.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "solana",
    "policy",
    "firewall",
    "agent",
    "dsl",
    "sentinel",
    "transaction"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dracian/Sentinal",
    "directory": "packages/policy-dsl"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "yaml": "^2.5.0",
    "zod": "^3.23.0",
    "json-stable-stringify": "^1.1.1"
  },
  "devDependencies": {
    "@types/json-stable-stringify": "^1.0.36",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.0"
  }
}
